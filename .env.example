# ==============================================================================
# PRE-START TASK: Day-0 Team Sync Agreements
# WHO DID THIS: Member A (Blockchain/DB) & Member C (AI/Data)
# WHAT WE DID: Defined the environment variables required for all three team members.
# WHY WE DID IT: To ensure the Frontend (B), Backend (A), and AI (C) all use the 
# same ports (e.g., 3001) and public keys from Day 1, avoiding configuration conflicts.
# ==============================================================================

# ── MEMBER A — Chain + DB ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=DU6wrsvShoAhnPtAiaxdEdjmuk8zZH8s3Aj5iqBiiSc6

# Public Keys for reference:
# SELLER_PUBKEY=CYqiXwY1b5snxDpcyZWMyAHJHoL1HR6W5sZgaMiMF7sW
# IMPORTER_PUBKEY=Aac9ghUvsgMgDKMTKKjdR4s9rf5c8cs6C3oUocPZKbkd
# LOGISTICS_PUBKEY=8vkjdjQx2PS1HXhdNbfAcMjogKKPkDa6di5He62BCM1N

SELLER_DEMO_KEYPAIR=[]          # JSON array of secret key bytes
IMPORTER_DEMO_KEYPAIR=[]
LOGISTICS_DEMO_KEYPAIR=[]

API_PORT=3001
DEMO_MODE=false

# ── MEMBER B — Frontend & MEMBER C — AI ──────────────────────────────
# ARCHITECTURE NOTE: Frontend and AI teams DO NOT interact with Solana directly!
# You will only interact with the Hono Backend API.
# 
# OPTION A (Host via Member A): Member A runs the Hono API and Solana Localnet.
# Member A will provide an Ngrok URL or local IP. Replace 'localhost' below with that URL.
# 
# OPTION B (Run locally): If you want to run the whole stack yourself, leave as localhost
# and run `solana-test-validator` + the Hono API locally.
NEXT_PUBLIC_API_URL=http://localhost:3001

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SOLANA_EXPLORER_BASE=https://explorer.solana.com/tx

# ── MEMBER C — AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key 
